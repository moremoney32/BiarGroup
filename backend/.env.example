# Serveur
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=biar_cpaas
DB_USER=
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_SECRET=

# Sécurité
CORS_ORIGIN=http://localhost:5173
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=

# Email API (mailer externe)
EMAIL_API_URL=
# Expéditeur principal — si vide, fallback sur biar.groupafrica@gmail.com
# Fallback de secours : noreply@solutravo-compta.fr
EMAIL_DEFAULT_SENDER=biar.groupafrica@gmail.com

# SMTP (multi)
SMTP_DEFAULT_HOST=
SMTP_DEFAULT_PORT=587
SMTP_DEFAULT_USER=
SMTP_DEFAULT_PASS=

# SMPP (SMS)
SMPP_HOST=
SMPP_PORT=2775
SMPP_SYSTEM_ID=
SMPP_PASSWORD=

# WhatsApp Business API
WA_API_URL=
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=

# Asterisk (Call Center)
AMI_HOST=localhost
AMI_PORT=5038
AMI_USER=
AMI_SECRET=

# Paiements
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log
